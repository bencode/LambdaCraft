---
// Page-level kernel status & reset bar for one language.
// Place ONCE per page per language (usually only needed for Python).
//   <KernelBar lang="python" />
import type { Lang } from './runtime/common/types'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
---

<div class="coderunner-kernel-bar" data-lang={lang}>
  <span class="kernel-bar-label">loading...</span>
  <span class="kernel-bar-status" data-state="idle">尚未启动</span>
  <button
    type="button"
    class="kernel-bar-btn"
    data-action="reset-kernel"
    title="清空本语言 kernel 的所有变量"
    disabled
  >
    ↺ 重置 kernel
  </button>
</div>

<script>
  import { initAllKernelBars } from './runtime/common/kernel-bar-controller'

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllKernelBars)
  } else {
    initAllKernelBars()
  }
</script>

<style is:global>
  .coderunner-kernel-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    margin: 1.5rem 0 1rem;
    border: 1px solid #d6dde6;
    border-radius: 8px;
    background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    font-family:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 13px;
  }

  .coderunner-kernel-bar .kernel-bar-label {
    font-weight: 600;
    color: #2d3748;
  }

  .coderunner-kernel-bar .kernel-bar-status {
    flex: 1;
    color: #4a5568;
    font-size: 12.5px;
  }

  .coderunner-kernel-bar .kernel-bar-status[data-state='loading'] {
    color: #b7791f;
  }

  .coderunner-kernel-bar .kernel-bar-status[data-state='ready'] {
    color: #2f855a;
  }

  .coderunner-kernel-bar .kernel-bar-status[data-state='error'] {
    color: #c53030;
  }

  .coderunner-kernel-bar .kernel-bar-btn {
    padding: 4px 10px;
    font-size: 12.5px;
    font-family: inherit;
    border: 1px solid #cbd5e0;
    border-radius: 4px;
    background: #ffffff;
    color: #2d3748;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  .coderunner-kernel-bar .kernel-bar-btn:hover:not(:disabled) {
    background: #fef5e7;
    border-color: #ed8936;
    color: #9c4221;
  }

  .coderunner-kernel-bar .kernel-bar-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
