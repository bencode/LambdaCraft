---
import type { Lang } from './runtime/common/types'

interface Props {
  lang: Lang
  code: string
  cellId?: string
  hint?: string
}

const {
  lang,
  code,
  cellId = `cell-${Math.random().toString(36).slice(2, 10)}`,
  hint,
} = Astro.props
---

<div
  class="coderunner-cell"
  data-cell-id={cellId}
  data-lang={lang}
  data-initial-code={code.replace(/^\n+|\n+$/g, '')}
>
  {hint && <div class="cell-hint">{hint}</div>}
  <div class="editor-wrap">
    <div class="editor-container"></div>
    <div class="cell-footer">
      <span class="cell-status" data-state="idle">Ctrl + Enter</span>
    </div>
  </div>
  <div class="output-container hidden"></div>
</div>

<script>
  import { initAllCells } from './runtime/common/cell-controller'

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllCells)
  } else {
    initAllCells()
  }
</script>

<style is:global>
  .coderunner-cell {
    border: 1px solid #e0e3e8;
    border-radius: 8px;
    margin: 1.5rem 0;
    background: #ffffff;
    overflow: hidden;
    font-family:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* Hint = author-supplied caption, sits above the editor as a clear
     section title. Visual weight comparable to a small heading. */
  .coderunner-cell .cell-hint {
    padding: 8px 12px;
    color: #2d3748;
    font-size: 13px;
    font-weight: 500;
    border-bottom: 1px solid #f0f3f7;
  }

  .coderunner-cell .editor-wrap {
    position: relative;
  }

  /* Footer overlays editor's bottom-right corner; absolute so it
     doesn't add a row of whitespace below the code. */
  .coderunner-cell .cell-footer {
    position: absolute;
    bottom: 2px;
    right: 6px;
    padding: 0 4px;
    font-size: 11px;
    background: rgba(255, 255, 255, 0.85);
    border-radius: 3px;
    pointer-events: none;
    opacity: 0.35;
    transition: opacity 0.2s ease;
  }

  .coderunner-cell:hover .cell-footer,
  .coderunner-cell:focus-within .cell-footer {
    opacity: 1;
  }

  .coderunner-cell .cell-status {
    color: #a0aec0;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .coderunner-cell .cell-status[data-state='running'] {
    color: #d69e2e;
  }

  .coderunner-cell .cell-status[data-state='error'] {
    color: #e53e3e;
  }

  .coderunner-cell .output-container {
    padding: 12px;
    background: #fcfcfd;
    font-size: 13px;
  }

  .coderunner-cell .output-container.hidden {
    display: none;
  }

  .coderunner-cell .coderunner-stdout,
  .coderunner-cell .coderunner-stderr,
  .coderunner-cell .coderunner-value,
  .coderunner-cell .coderunner-error {
    margin: 0 0 8px;
    padding: 8px 10px;
    border-radius: 4px;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12.5px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .coderunner-cell .coderunner-stdout {
    background: #f7fafc;
    color: #1a202c;
  }

  .coderunner-cell .coderunner-stderr {
    background: #fffaf0;
    color: #744210;
  }

  .coderunner-cell .coderunner-value {
    background: #f0fff4;
    color: #22543d;
    border-left: 3px solid #48bb78;
  }

  .coderunner-cell .coderunner-error {
    background: #fff5f5;
    color: #742a2a;
    border-left: 3px solid #f56565;
  }

  .coderunner-cell .coderunner-image {
    margin: 0 0 8px;
    text-align: center;
  }

  .coderunner-cell .coderunner-image img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .coderunner-cell .coderunner-html {
    margin: 0 0 8px;
    overflow-x: auto;
  }

  .coderunner-cell table.coderunner-df {
    border-collapse: collapse;
    font-size: 12px;
  }

  .coderunner-cell table.coderunner-df th,
  .coderunner-cell table.coderunner-df td {
    border: 1px solid #e0e3e8;
    padding: 4px 8px;
  }

  .coderunner-cell table.coderunner-df th {
    background: #f7fafc;
    font-weight: 600;
  }

  .coderunner-cell .coderunner-status {
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 12px;
  }

  .coderunner-cell .coderunner-status--info {
    background: #ebf8ff;
    color: #2b6cb0;
  }

  .coderunner-cell .coderunner-status--error {
    background: #fff5f5;
    color: #742a2a;
  }
</style>
