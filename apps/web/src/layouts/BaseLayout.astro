---
import 'katex/dist/katex.min.css'
import '../styles/global.css'

type Props = {
  title: string
  description?: string
  hasToc?: boolean
}

const { title, description, hasToc = false } = Astro.props
const siteName = 'LambdaCraft'
const fullTitle = title === siteName ? title : `${title} · ${siteName}`

const path = Astro.url.pathname
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`)

const navItems: Array<{ href: string; label: string }> = [
  { href: '/', label: 'home' },
  { href: '/posts', label: 'posts' },
  { href: '/reading', label: 'reading' },
  { href: '/forge', label: 'forge' },
]
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {description && <meta name="description" content={description} />}
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site">
        <a class="brand" href="/">(define lambdacraft)</a>
        <nav>
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}> {item.label} </a>
            ))
          }
        </nav>
      </header>

      <main class="layout" data-has-toc={hasToc ? 'true' : 'false'}>
        <slot />
        {hasToc && <slot name="toc" />}
      </main>

      <footer class="site">
        <span>(λ () (study math) (practice code))</span>
        <span>© {new Date().getFullYear()} qijun.io</span>
      </footer>
    </div>
  </body>
</html>
