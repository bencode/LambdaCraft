---
import 'katex/dist/katex.min.css'
import '../styles/global.css'

type Props = {
  title: string
  description?: string
  hasToc?: boolean
}

const { title, description, hasToc = false } = Astro.props
const siteName = 'LambdaCraft'
const fullTitle = title === siteName ? title : `${title} · ${siteName}`

const path = Astro.url.pathname
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`)

const navItems: Array<{ href: string; label: string }> = [
  { href: '/', label: 'home' },
  { href: '/posts', label: 'posts' },
  { href: '/reading', label: 'reading' },
  { href: '/forge', label: 'forge' },
  { href: '/about', label: 'about' },
]
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {description && <meta name="description" content={description} />}
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site">
        <a class="brand" href="/">(define lambdacraft)</a>
        <nav>
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}> {item.label} </a>
            ))
          }
        </nav>
      </header>

      <main class="layout" data-has-toc={hasToc ? 'true' : 'false'}>
        <slot />
      </main>

      <footer class="site">
        <span>(λ () (study math) (practice code))</span>
        <span>© {new Date().getFullYear()} qijun.io</span>
      </footer>
    </div>

    {hasToc && (
      <>
        <button
          type="button"
          class="toc-toggle"
          data-action="toggle-toc"
          aria-label="切换目录"
          aria-expanded="false"
        >
          ☰ 目录
        </button>
        <aside class="toc-drawer" data-state="closed" aria-hidden="true">
          <div class="toc-drawer-backdrop"></div>
          <div class="toc-drawer-panel">
            <slot name="toc" />
          </div>
        </aside>
      </>
    )}

    <script>
      import { initTocDrawer } from '../components/toc-drawer-controller'
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTocDrawer)
      } else {
        initTocDrawer()
      }
    </script>
  </body>
</html>
