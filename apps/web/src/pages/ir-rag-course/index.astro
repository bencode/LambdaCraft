---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const all = await getCollection('ir-rag-course')
// top-level hub.mdx 在 brain2 源里；旧命名 _index.mdx 兼容
const indexEntry = all.find((e) => e.id === 'hub' || e.id === '_index')

if (!indexEntry) {
  throw new Error('ir-rag-course top-level hub not found (expected hub.mdx or _index.mdx)')
}

const { Content } = await render(indexEntry)
---

<BaseLayout
  title={indexEntry.data.title ?? 'IR / RAG 主题式系列课程'}
  description={indexEntry.data.summary}
>
  <article>
    <Content />
  </article>
</BaseLayout>
