---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { bookOfEntry, chapterLabel, slugInBook, titleFromBody } from '../lib/books'

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)

const readingAll = await getCollection('reading')
const readingRecent = readingAll
  .map((entry) => {
    const book = bookOfEntry(entry.id)
    if (!book) return null
    const slug = slugInBook(entry.id, book)
    return {
      bookId: book.id,
      slug,
      label: chapterLabel(slug),
      title: titleFromBody(entry.body, slug),
    }
  })
  .filter((x): x is { bookId: string; slug: string; label: string; title: string } => x !== null)
  .sort((a, b) => b.slug.localeCompare(a.slug))
  .slice(0, 5)

const fmt = (d: Date) => d.toISOString().slice(0, 10)
---

<BaseLayout title="LambdaCraft" description="A place to study math and practice code.">
  <article>
    <section class="section">
      <div class="section-head">
        <span class="label">Recent Posts</span>
        <span class="rule" />
        <a class="more" href="/posts">All →</a>
      </div>
      {
        posts.length === 0 ? (
          <p class="empty">nothing yet</p>
        ) : (
          <ul class="entry-list">
            {posts.map((post) => (
              <li>
                <time class="meta" datetime={post.data.date.toISOString()}>
                  {fmt(post.data.date)}
                </time>
                <a href={`/posts/${post.id}`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <section class="section">
      <div class="section-head">
        <span class="label">Recent Reading</span>
        <span class="rule" />
        <a class="more" href="/reading">All →</a>
      </div>
      {
        readingRecent.length === 0 ? (
          <p class="empty">nothing yet</p>
        ) : (
          <ul class="entry-list">
            {readingRecent.map((r) => (
              <li>
                <span class="meta">
                  {r.bookId} <span class="sep">·</span> {r.label}
                </span>
                <a href={`/reading/${r.bookId}/${r.slug}`}>{r.title}</a>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </article>
</BaseLayout>
