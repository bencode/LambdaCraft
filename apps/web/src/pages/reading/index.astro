---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { extractFormalSeries } from '../../lib/formal-reading'

const formalAll = await getCollection('ir-rag')
const seriesList = extractFormalSeries(formalAll)
---

<BaseLayout title="Reading" description="Formal articles">
  <article>
    <h1>Reading</h1>
    <p class="chapter-meta">正式文章</p>
    {
      seriesList.length === 0 ? (
        <p class="empty">nothing yet</p>
      ) : (
        <ul class="series-tree">
          {seriesList.map((series) => (
            <li class="series-tree-group">
              <a class="series-tree-hub" href={series.href}>
                {series.title}
              </a>
              {series.articles.length > 0 && (
                <ul class="series-tree-children">
                  {series.articles.map((article) => (
                    <li class="series-tree-row">
                      <span class="connector" aria-hidden="true">└─</span>
                      <a class="title" href={article.href}>
                        {article.title}
                      </a>
                      {article.draft && <span class="draft-tag">写中</span>}
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</BaseLayout>
