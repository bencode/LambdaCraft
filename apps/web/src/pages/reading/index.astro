---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { books } from '../../lib/books'
---

<BaseLayout title="Reading" description="Reading notes">
  <article>
    <h1>Reading</h1>
    <p class="chapter-meta">读书笔记</p>
    <ul class="book-list">
      {
        books.map((book) => (
          <li>
            <div class="book-id">{book.id}</div>
            <a class="book-title" href={`/reading/${book.id}`}>
              {book.title}
            </a>
            {book.subtitle && <div class="book-subtitle">{book.subtitle}</div>}
          </li>
        ))
      }
    </ul>
  </article>
</BaseLayout>
