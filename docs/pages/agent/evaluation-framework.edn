tion"]] [:<> " 和 "] [:code [:<> "advanced-evaluation"]] [:<> " 两个核心技能，以及 "] [:code [:<> "llm-as-judge-skills"]] [:<> " 示例的内容。"]] ["h2" {:id "为什么需要-llm-as-judge"} [:<> "为什么需要 LLM-as-Judge"]] ["h3" {:id "传统评估方法的局限"} [:<> "传统评估方法的局限"]] [:table [:thead [:tr [:th {:style nil} [:<> "方法"]] [:th {:style nil} [:<> "优点"]] [:th {:style nil} [:<> "缺点"]]]] [:tbody [:tr [:td {:style nil} [:<> "人工评估"]] [:td {:style nil} [:<> "准确、可信"]] [:td {:style nil} [:<> "成本高、速度慢、难以扩展"]]] [:tr [:td {:style nil} [:<> "规则评估"]] [:td {:style nil} [:<> "快速、确定"]] [:td {:style nil} [:<> "无法评估创造性、复杂性"]]] [:tr [:td {:style nil} [:<> "指标评估"]] [:td {:style nil} [:<> "客观、可重复"]] [:td {:style nil} [:<> "无法捕捉质量的细微差别"]]]]] ["h3" {:id "llm-as-judge-的优势"} [:<> "LLM-as-Judge 的优势"]] [:ul [:li [:<> [:strong [:<> "可扩展"]] [:<> "：自动化评估，无需人工干预"]]] [:li [:<> [:strong [:<> "一致性"]] [:<> "：评分标准统一（相比多个人类评估者）"]]] [:li [:<> [:strong [:<> "细粒度"]] [:<> "：可以评估复杂的质量维度"]]] [:li [:<> [:strong [:<> "可定制"]] [:<> "：根据任务调整评估标准"]]]] ["h3" {:id "适用场景"} [:<> "适用场景"]] [:ul [:li [:<> [:<> "快速迭代开发，需要持续评估"]]] [:li [:<> [:<> "大规模 A/B 测试"]]] [:li [:<> [:<> "回归测试（确保更新没有降低质量）"]]] [:li [:<> [:<> "初步筛选（人工评估前的过滤）"]]]] ["h2" {:id "多维度评分框架"} [:<> "多维度评分框架"]] ["h3" {:id "单一评分的问题"} [:<> "单一评分的问题"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "评分：7/10", :nextjournal/render-opts {:language "clojure"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:<> "这无法回答："]] [:ul [:li [:<> [:<> "哪些方面做得好？"]]] [:li [:<> [:<> "哪些方面需要改进？"]]] [:li [:<> [:<> "为什么是 7 而不是 6 或 8？"]]]] ["h3" {:id "多维度评分"} [:<> "多维度评分"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type MultiDimensionalScore = {\n  accuracy: number       // 事实准确性\n  completeness: number   // 覆盖完整性\n  efficiency: number     // Token 和步骤效率\n  quality: number        // 输出质量（代码、文本）\n  process: number        // 推理过程质量\n  overall: number        // 加权总分\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h3" {:id "x-to-book-的-5-维评估"} [:<> "X-to-Book 的 5 维评估"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type BookEvaluation = {\n  accuracy: number       // 事实准确性（与原推文一致性）\n  completeness: number   // 覆盖完整性（是否包含关键观点）\n  coherence: number      // 叙事连贯性（章节衔接）\n  insight: number        // 洞察深度（是否发现模式/趋势）\n  style: number          // 写作质量（可读性、引人入胜）\n\n  overall: number        // 加权平均\n  weights: {\n    accuracy: 0.3\n    completeness: 0.2\n    coherence: 0.2\n    insight: 0.15\n    style: 0.15\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h3" {:id "加权计算"} [:<> "加权计算"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "function calculateOverall(scores: MultiDimensionalScore): number {\n  const weights = {\n    accuracy: 0.3,\n    completeness: 0.2,\n    efficiency: 0.15,\n    quality: 0.2,\n    process: 0.15\n  }\n\n  return Object.entries(weights).reduce((total, [dim, weight]) => {\n    return total + scores[dim] * weight\n  }, 0)\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h2" {:id "三种评估方法"} [:<> "三种评估方法"]] ["h3" {:id "1.-直接评分（direct-scoring）"} [:<> "1. 直接评分（Direct Scoring）"]] ["h4" {:id "原理"} [:<> "原理"]] [:p [:<> "要求 LLM 直接对输出进行评分。"]] ["h4" {:id "提示模板"} [:<> "提示模板"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "const directScoringPrompt = `\nYou are an expert evaluator for AI Agent systems.\n\nTask: ${task}\nAgent Output: ${output}\nReference (if available): ${reference}\n\nEvaluate the agent output across these dimensions:\n1. Accuracy (0-10): Is the output factually correct?\n2. Completeness (0-10): Does it fully address the task?\n3. Quality (0-10): Is the output well-structured and clear?\n\nFor each dimension:\n- Provide a score (0-10)\n- Explain your reasoning (2-3 sentences)\n\nUse this format:\n<evaluation>\n<accuracy>\n<score>8</score>\n<reasoning>The output correctly identifies...</reasoning>\n</accuracy>\n<completeness>\n<score>7</score>\n<reasoning>The output addresses most requirements but misses...</reasoning>\n</completeness>\n<quality>\n<score>9</score>\n<reasoning>The output is well-structured with...</reasoning>\n</quality>\n</evaluation>\n`", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h4" {:id "实现"} [:<> "实现"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "import { z } from \"zod\"\n\nconst DimensionScoreSchema = z.object({\n  score: z.number().min(0).max(10),\n  reasoning: z.string().min(10)\n})\n\nconst DirectScoringSchema = z.object({\n  accuracy: DimensionScoreSchema,\n  completeness: DimensionScoreSchema,\n  quality: DimensionScoreSchema\n})\n\ntype DirectScoringResult = z.infer<typeof DirectScoringSchema>\n\nasync function directScoring(\n  task: string,\n  output: string,\n  reference?: string\n): Promise<DirectScoringResult> {\n  const prompt = buildDirectScoringPrompt(task, output, reference)\n\n  const response = await callLLM(prompt, {\n    model: \"claude-sonnet-4-5\",\n    temperature: 0.3  // 低温度保证一致性\n  })\n\n  const parsed = parseXMLResponse(response)\n\n  // Zod 验证\n  return DirectScoringSchema.parse(parsed)\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h4" {:id "优点"} [:<> "优点"]] [:ul [:li [:<> [:<> "实现简单"]]] [:li [:<> [:<> "获得具体的评分和理由"]]]] ["h4" {:id "缺点"} [:<> "缺点"]] [:ul [:li [:<> [:<> "容易受绝对评分标准的主观性影响"]]] [:li [:<> [:<> "不同批次的评分可能不一致（即使同一输出）"]]]] ["h3" {:id "2.-配对比较（pairwise-comparison）"} [:<> "2. 配对比较（Pairwise Comparison）"]] ["h4" {:id "原理-2"} [:<> "原理"]] [:p [:<> "要求 LLM 比较两个输出，选择更好的一个。相比直接评分，配对比较更稳定。"]] ["h4" {:id "提示模板-2"} [:<> "提示模板"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "const pairwiseComparisonPrompt = `\nYou are comparing two AI Agent outputs for the same task.\n\nTask: ${task}\n\nOutput A:\n${outputA}\n\nOutput B:\n${outputB}\n\nWhich output is better overall? Consider:\n- Accuracy\n- Completeness\n- Quality\n\nThink step-by-step, then choose:\nA. Output A is better\nB. Output B is better\nC. They are roughly equal\n\nProvide your reasoning (3-5 sentences), then state your choice.\n\nFormat:\n<comparison>\n<reasoning>...</reasoning>\n<choice>A</choice>\n</comparison>\n`", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h4" {:id "实现-2"} [:<> "实现"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type PairwiseResult = {\n  winner: \"A\" | \"B\" | \"tie\"\n  reasoning: string\n  confidence: number  // 0-1\n}\n\nconst PairwiseSchema = z.object({\n  reasoning: z.string(),\n  choice: z.enum([\"A\", \"B\", \"C\"])\n})\n\nasync function pairwiseComparison(\n  task: string,\n  outputA: string,\n  outputB: string,\n  swapPositions: boolean = false\n): Promise<PairwiseResult> {\n  // 位置偏见缓解：交换位置评估两次\n  const [first, second] = swapPositions ? [outputB, outputA] : [outputA, outputB]\n\n  const prompt = buildPairwisePrompt(task, first, second)\n\n  const response = await callLLM(prompt, {\n    model: \"claude-sonnet-4-5\",\n    temperature: 0.3\n  })\n\n  const parsed = PairwiseSchema.parse(parseXMLResponse(response))\n\n  let winner: \"A\" | \"B\" | \"tie\"\n  if (parsed.choice === \"C\") {\n    winner = \"tie\"\n  } else if (swapPositions) {\n    // 交换回来\n    winner = parsed.choice === \"A\" ? \"B\" : \"A\"\n  } else {\n    winner = parsed.choice\n  }\n\n  return {\n    winner,\n    reasoning: parsed.reasoning,\n    confidence: 0.8  // 可通过多次评估计算真实置信度\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h4" {:id "位置偏见缓解"} [:<> "位置偏见缓解"]] [:p [:<> "LLM 存在"] [:strong [:<> "位置偏见"]] [:<> "：倾向于选择第一个或最后一个选项。"]] [:p [:strong [:<> "解决方案"]] [:<> "：交换位置评估两次"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "async function pairwiseComparisonWithBiasMitigation(\n  task: string,\n  outputA: string,\n  outputB: string\n): Promise<PairwiseResult> {\n  // 第一次：A在前，B在后\n  const result1 = await pairwiseComparison(task, outputA, outputB, false)\n\n  // 第二次：B在前，A在后\n  const result2 = await pairwiseComparison(task, outputA, outputB, true)\n\n  // 一致性检查\n  if (result1.winner === result2.winner) {\n    return {\n      ...result1,\n      confidence: 0.95  // 两次一致，高置信度\n    }\n  } else if (result1.winner === \"tie\" || result2.winner === \"tie\") {\n    return {\n      winner: \"tie\",\n      reasoning: \"Inconsistent results suggest outputs are roughly equal\",\n      confidence: 0.5\n    }\n  } else {\n    return {\n      winner: \"tie\",\n      reasoning: \"Position bias detected - conflicting results\",\n      confidence: 0.3\n    }\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h4" {:id "优点-2"} [:<> "优点"]] [:ul [:li [:<> [:<> "比直接评分更稳定"]]] [:li [:<> [:<> "适合偏好排序（如选择最佳提示）"]]]] ["h4" {:id "缺点-2"} [:<> "缺点"]] [:ul [:li [:<> [:<> "需要成对比较，O(n²) 复杂度"]]] [:li [:<> [:<> "不能提供绝对评分"]]]] ["h3" {:id "3.-标准生成（rubric-generation）"} [:<> "3. 标准生成（Rubric Generation）"]] ["h4" {:id "原理-3"} [:<> "原理"]] [:p [:<> "先让 LLM 生成评分标准（rubric），再基于标准评分。这使评分更一致和可解释。"]] ["h4" {:id "第一步：生成标准"} [:<> "第一步：生成标准"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "const rubricGenerationPrompt = `\nYou are creating an evaluation rubric for the following task:\n\nTask: ${task}\nSample Outputs:\n${sampleOutputs}\n\nGenerate a detailed rubric with 3-5 dimensions.\nFor each dimension, provide:\n1. Name and description\n2. 3 levels: Excellent (8-10), Adequate (5-7), Poor (0-4)\n3. Specific criteria for each level\n\nFormat:\n<rubric>\n<dimension name=\"accuracy\">\n<description>...</description>\n<excellent>...</excellent>\n<adequate>...</adequate>\n<poor>...</poor>\n</dimension>\n...\n</rubric>\n`", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h4" {:id "第二步：基于标准评分"} [:<> "第二步：基于标准评分"]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "const rubricBasedScoringPrompt = `\nUsing the following rubric:\n${rubric}\n\nEvaluate this output:\nTask: ${task}\nOutput: ${output}\n\nFor each dimension in the rubric:\n1. Determine which level the output falls into\n2. Assign a specific score within that level's range\n3. Explain your reasoning\n\nFormat