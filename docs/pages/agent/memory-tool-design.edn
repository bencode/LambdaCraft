t-presented] {:path [0], :nextjournal/value "<working_memory>\n<current_task>\n实现用户认证的 JWT 刷新机制\n</current_task>\n\n<recent_context>\n- 已实现 JWT 生成和验证\n- 已创建 /auth/login 端点\n- 下一步：实现 /auth/refresh 端点\n</recent_context>\n\n<active_files>\n- src/auth/jwt.ts\n- src/auth/refresh.ts\n</active_files>\n</working_memory>", :nextjournal/render-opts {:language "markdown"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "管理策略"]] [:<> "："]] [:ul [:li [:<> [:<> "优先级最高的信息放在这里"]]] [:li [:<> [:<> "当接近容量时，触发压缩到短期内存"]]]] ["h3" {:id "2.-短期内存（short-term-memory）"} [:<> "2. 短期内存（Short-term Memory）"]] [:p [:strong [:<> "定义"]] [:<> "：当前会话的压缩历史，跨多个请求。"]] [:p [:strong [:<> "特点"]] [:<> "："]] [:ul [:li [:<> [:<> "容量：10-50K tokens（压缩后）"]]] [:li [:<> [:<> "持久性：会话级（几小时到几天）"]]] [:li [:<> [:<> "访问速度：快（加载到工作内存）"]]]] [:p [:strong [:<> "实现"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type ShortTermMemory = {\n  sessionId: string\n  summary: string\n  decisions: string[]\n  filesModified: string[]\n  nextSteps: string[]\n  createdAt: Date\n  updatedAt: Date\n}\n\nclass ShortTermMemoryManager {\n  async save(memory: ShortTermMemory): Promise<void> {\n    const filePath = `/tmp/stm_${memory.sessionId}.json`\n    await writeFile(filePath, JSON.stringify(memory, null, 2))\n  }\n\n  async load(sessionId: string): Promise<ShortTermMemory | null> {\n    const filePath = `/tmp/stm_${sessionId}.json`\n\n    if (!await exists(filePath)) {\n      return null\n    }\n\n    const content = await readFile(filePath, \"utf-8\")\n    return JSON.parse(content)\n  }\n\n  async compress(workingMemory: string): Promise<ShortTermMemory> {\n    const prompt = `\nCompress the following working memory into a structured summary:\n\n${workingMemory}\n\nExtract:\n1. Key decisions made\n2. Files modified\n3. Next steps\n4. Brief summary of discussion\n`\n\n    const result = await callLLM(prompt)\n\n    return {\n      sessionId: generateSessionId(),\n      summary: result.summary,\n      decisions: result.decisions,\n      filesModified: result.filesModified,\n      nextSteps: result.nextSteps,\n      createdAt: new Date(),\n      updatedAt: new Date()\n    }\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "示例"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "{\n  \"sessionId\": \"session_20250101_001\",\n  \"summary\": \"实现了用户认证系统的 JWT 生成和验证功能。选择使用 RS256 算法，刷新令牌有效期为7天。\",\n  \"decisions\": [\n    \"使用 RS256 而非 HS256（更安全）\",\n    \"刷新令牌有效期：7天\",\n    \"将黑名单存储在 Redis\"\n  ],\n  \"filesModified\": [\n    \"src/auth/jwt.ts\",\n    \"src/auth/login.ts\",\n    \"src/middleware/auth.ts\"\n  ],\n  \"nextSteps\": [\n    \"实现 /auth/refresh 端点\",\n    \"添加黑名单检查中间件\",\n    \"编写单元测试\"\n  ],\n  \"createdAt\": \"2025-01-01T10:00:00Z\",\n  \"updatedAt\": \"2025-01-01T12:30:00Z\"\n}", :nextjournal/render-opts {:language "json"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h3" {:id "3.-长期内存（long-term-memory）"} [:<> "3. 长期内存（Long-term Memory）"]] [:p [:strong [:<> "定义"]] [:<> "：跨会话的持久化内存，使用向量检索。"]] [:p [:strong [:<> "特点"]] [:<> "："]] [:ul [:li [:<> [:<> "容量：无限（外部存储）"]]] [:li [:<> [:<> "持久性：永久"]]] [:li [:<> [:<> "访问速度：中等（需要检索）"]]]] [:p [:strong [:<> "实现"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type LongTermMemoryEntry = {\n  id: string\n  content: string\n  embedding: number[]\n  metadata: {\n    timestamp: Date\n    sessionId: string\n    tags: string[]\n  }\n}\n\nclass LongTermMemoryManager {\n  private vectorDB: VectorDatabase\n\n  async store(content: string, metadata: Record<string, any>): Promise<void> {\n    const embedding = await this.getEmbedding(content)\n\n    const entry: LongTermMemoryEntry = {\n      id: generateId(),\n      content,\n      embedding,\n      metadata: {\n        timestamp: new Date(),\n        ...metadata\n      }\n    }\n\n    await this.vectorDB.insert(entry)\n  }\n\n  async retrieve(\n    query: string,\n    limit: number = 5\n  ): Promise<LongTermMemoryEntry[]> {\n    const queryEmbedding = await this.getEmbedding(query)\n\n    return await this.vectorDB.search(queryEmbedding, limit)\n  }\n\n  private async getEmbedding(text: string): Promise<number[]> {\n    // 使用 OpenAI embeddings 或其他嵌入模型\n    return await openai.embeddings.create({\n      model: \"text-embedding-3-small\",\n      input: text\n    })\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "使用场景"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "// 存储过去的决策\nawait ltm.store(\n  \"决定使用 PostgreSQL 作为主数据库，因为需要 ACID 保证和复杂查询支持\",\n  { tags: [\"decision\", \"database\"], sessionId: \"session_001\" }\n)\n\n// 检索相关历史\nconst relevant = await ltm.retrieve(\n  \"选择什么数据库存储用户会话？\"\n)\n\n// 将检索结果加载到工作内存\nconst context = relevant.map(r => r.content).join(\"\\n\\n\")", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h3" {:id "4.-实体内存（entity-memory）"} [:<> "4. 实体内存（Entity Memory）"]] [:p [:strong [:<> "定义"]] [:<> "：结构化的实体信息存储（人物、项目、概念等）。"]] [:p [:strong [:<> "特点"]] [:<> "："]] [:ul [:li [:<> [:<> "容量：无限"]]] [:li [:<> [:<> "持久性：永久"]]] [:li [:<> [:<> "访问速度：快（结构化查询）"]]]] [:p [:strong [:<> "Schema"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type Entity = {\n  id: string\n  type: \"person\" | \"project\" | \"concept\" | \"file\"\n  name: string\n  attributes: Record<string, any>\n  relationships: Relationship[]\n  history: HistoryEntry[]\n}\n\ntype Relationship = {\n  targetId: string\n  type: string\n  metadata: Record<string, any>\n}\n\ntype HistoryEntry = {\n  timestamp: Date\n  event: string\n  data: Record<string, any>\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "实现"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "class EntityMemoryManager {\n  async createEntity(entity: Entity): Promise<void> {\n    const filePath = `/storage/entities/${entity.type}/${entity.id}.json`\n    await writeFile(filePath, JSON.stringify(entity, null, 2))\n  }\n\n  async getEntity(id: string): Promise<Entity | null> {\n    // 扫描所有类型目录\n    const types = [\"person\", \"project\", \"concept\", \"file\"]\n\n    for (const type of types) {\n      const filePath = `/storage/entities/${type}/${id}.json`\n      if (await exists(filePath)) {\n        const content = await readFile(filePath, \"utf-8\")\n        return JSON.parse(content)\n      }\n    }\n\n    return null\n  }\n\n  async updateEntity(id: string, update: Partial<Entity>): Promise<void> {\n    const entity = await this.getEntity(id)\n    if (!entity) {\n      throw new Error(`Entity ${id} not found`)\n    }\n\n    const updated = { ...entity, ...update }\n\n    // 添加历史记录\n    updated.history.push({\n      timestamp: new Date(),\n      event: \"update\",\n      data: update\n    })\n\n    const filePath = `/storage/entities/${entity.type}/${id}.json`\n    await writeFile(filePath, JSON.stringify(updated, null, 2))\n  }\n\n  async query(query: EntityQuery): Promise<Entity[]> {\n    // 实现灵活的查询逻辑\n    const allEntities = await this.loadAllEntities()\n\n    return allEntities.filter(entity => {\n      if (query.type && entity.type !== query.type) return false\n      if (query.name && !entity.name.includes(query.name)) return false\n      if (query.hasAttribute) {\n        const [key, value] = query.hasAttribute\n        if (entity.attributes[key] !== value) return false\n      }\n      return true\n    })\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "示例"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "{\n  \"id\": \"user_alice\",\n  \"type\": \"person\",\n  \"name\": \"Alice Smith\",\n  \"attributes\": {\n    \"role\": \"Frontend Developer\",\n    \"email\": \"alice@example.com\",\n    \"preferences\": {\n      \"framework\": \"React\",\n      \"styling\": \"Tailwind CSS\"\n    }\n  },\n  \"relationships\": [\n    {\n      \"targetId\": \"project_webapp\",\n      \"type\": \"contributes_to\",\n      \"metadata\": { \"role\": \"lead\" }\n    }\n  ],\n  \"history\": [\n    {\n      \"timestamp\": \"2025-01-01T10:00:00Z\",\n      \"event\": \"created\",\n      \"data\": {}\n    },\n    {\n      \"timestamp\": \"2025-01-05T15:30:00Z\",\n      \"event\": \"update\",\n      \"data\": { \"attributes\": { \"role\": \"Frontend Lead\" } }\n    }\n  ]\n}", :nextjournal/render-opts {:language "json"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] ["h3" {:id "5.-时间知识图（temporal-knowledge-graph）"} [:<> "5. 时间知识图（Temporal Knowledge Graph）"]] [:p [:strong [:<> "定义"]] [:<> "：追踪实体和关系随时间的演变。"]] [:p [:strong [:<> "特点"]] [:<> "："]] [:ul [:li [:<> [:<> "容量：无限"]]] [:li [:<> [:<> "持久性：永久"]]] [:li [:<> [:<> "访问速度：中等（图查询）"]]]] [:p [:strong [:<> "Schema"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "type TemporalNode = {\n  entityId: string\n  timestamp: Date\n  snapshot: Record<string, any>\n}\n\ntype TemporalEdge = {\n  sourceId: string\n  targetId: string\n  type: string\n  validFrom: Date\n  validUntil: Date | null\n  metadata: Record<string, any>\n}\n\ntype TemporalKnowledgeGraph = {\n  nodes: TemporalNode[]\n  edges: TemporalEdge[]\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "实现"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "class TemporalKnowledgeGraphManager {\n  async addSnapshot(\n    entityId: string,\n    snapshot: Record<string, any>\n  ): Promise<void> {\n    const node: TemporalNode = {\n      entityId,\n      timestamp: new Date(),\n      snapshot\n    }\n\n    await this.appendToGraph(node)\n  }\n\n  async addRelationship(\n    sourceId: string,\n    targetId: string,\n    type: string,\n    metadata: Record<string, any> = {}\n  ): Promise<void> {\n    const edge: TemporalEdge = {\n      sourceId,\n      targetId,\n      type,\n      validFrom: new Date(),\n      validUntil: null,\n      metadata\n    }\n\n    await this.appendToGraph(edge)\n  }\n\n  async endRelationship(\n    sourceId: string,\n    targetId: string,\n    type: string\n  ): Promise<void> {\n    const edges = await this.findEdges(sourceId, targetId, type)\n\n    for (const edge of edges) {\n      if (edge.validUntil === null) {\n        edge.validUntil = new Date()\n        await this.updateEdge(edge)\n      }\n    }\n  }\n\n  async getEvolution(\n    entityId: string,\n    from: Date,\n    to: Date\n  ): Promise<TemporalNode[]> {\n    const nodes = await this.loadNodes()\n\n    return nodes.filter(node =>\n      node.entityId === entityId &&\n      node.timestamp >= from &&\n      node.timestamp <= to\n    )\n  }\n\n  async queryAtTime(\n    entityId: string,\n    timestamp: Date\n  ): Promise<Record<string, any>> {\n    const nodes = await this.getEvolution(\n      entityId,\n      new Date(0),\n      timestamp\n    )\n\n    // 返回最接近但不晚于指定时间的快照\n    return nodes[nodes.length - 1]?.snapshot || {}\n  }\n}", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1CcHNbRHnK2sVyn7YUmXB"}}] [:p [:strong [:<> "使用示例（X-to-Book 案例）"]] [:<> "："]] [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:nextjournal/value [:div.code-viewer.code-listing [#clerk/render-fn+opts [{:eval true} nextjournal.clerk.render/inspect-presented] {:path [0], :nextjournal/value "// 追踪 Elon Musk 对 AI 的观点演变\nawait tkg.addSnapshot(\"elon_musk\", {\n  topic: \"AI safety\",\n  stance: \"optimistic\",\n  evidence: \"Tweet: AI will bring prosperity\"\n})\n\n// 15天后\nawait tkg.addSnapshot(\"elon_musk\", {\n  topic: \"AI safety\",\n  stance: \"concerned\",\n  evidence: \"Tweet: We need AI regulation\"\n})\n\n// 查询演变\nconst evolution = await tkg.getEvolution(\n  \"elon_musk\",\n  new Date(\"2025-01-01\"),\n  new Date(\"2025-01-31\")\n)\n\n// 生成叙述\nconst narrative = `\nElon Musk's stance on AI safety evolved significantly:\n- Early January: Optimistic, focused on prosperity\n- Mid January: Shift to concern, calling for regulation\n`", :nextjournal/render-opts {:language "typescript"}, :nextjournal/viewer {:name nextjournal.clerk.viewer/code-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-code], :hash "5dsJQw12yyyd7TcZEf52VSHxnqnJUC"}}]], :nextjournal/viewer {:name nextjournal.clerk.viewer/html-viewer, :render-fn #clerk/render-fn+opts [{:render-evaluator :sci} nextjournal.clerk.render/render-html], :hash "5drpr3yzJ1